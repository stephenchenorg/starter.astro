# Astro Adapter 切換
# 使用自訂變數 is_netlify 而非 NETLIFY，因為 Netlify 會自動設定 NETLIFY=true
# 這樣可以在 Netlify 環境中選擇使用 Node adapter 進行測試
# 設為 "true" 使用 @astrojs/netlify，未設定則使用 @astrojs/node
is_netlify=

# 本站對外部署的完整網址 (含 protocol)
# 用途：
#   1. astro.config.ts 的 site (影響 sitemap / canonical URL)
#   2. security.allowedDomains (Astro 5.14+ host header 驗證；
#      未設定會導致同源表單提交被擋 → Cross-site form submissions are forbidden)
# Local dev 可不填 (會 fallback 到 http://localhost:4321)
# Staging / Production 必須在部署平台 (Netlify / Vercel / Node host) 設定
SITE_URL=

# API 網域
API_BASE_URL="https://dev-admin.csstudio.tw"

# Astro Cookie Session 加密金鑰
SECRET_KEY_BASE=

# GA4 Tracking ID, must be set to enable Google Analytics first and ID is starting with "G-"
# Format: G-XXXXXXXXXX
GA4_TRACKING_ID=

# Google Tag Manager ID, must be set to enable GTM and ID is starting with "GTM-"
# Format: GTM-XXXXXXX
# Recommended: Use GTM to manage all tracking tags in one place
GTM_ID=

# LINE Tag ID for Taiwan market advertising
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LINE_TAG_ID=

# Microsoft Clarity ID for user behavior analytics
# Format: xxxxxxxxxx
CLARITY_ID=

# Facebook Pixel ID for Facebook advertising
# Format: xxxxxxxxxxxxxxx (15-16 digits)
FB_PIXEL_ID=
